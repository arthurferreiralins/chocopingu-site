{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "**/*.html", "use": "@vercel/static" },
    { "src": "**/*.{css,js,png,ico,jpg,jpeg,webm,svg,mp4}", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1.js" },
    { "src": "/admin(.*)", "status": 404 },
    { "src": "/pedir(.*)", "status": 404 },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
